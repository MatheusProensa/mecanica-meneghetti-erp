# Banco de dados (Supabase Postgres)
DATABASE_URL=

# NextAuth (v5) — segredo usado para assinar sessões JWT
AUTH_SECRET=
NEXTAUTH_URL=

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Envio de e-mail (Resend) — usado em "esqueci minha senha"
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Opcional — usados apenas por prisma/seed.ts para criar o primeiro usuário Dono
SEED_OWNER_EMAIL=
SEED_OWNER_NAME=
SEED_OWNER_PASSWORD=

# Notificações push (resumo diário de OS atrasadas/dívidas em aberto)
# Gerar com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@oficina.local

# Segredo que o Vercel Cron envia pra autenticar a chamada da rotina diária
CRON_SECRET=
