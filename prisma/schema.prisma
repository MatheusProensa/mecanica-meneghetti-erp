// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  pixKey              String?
  dadosBancarios      String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())

  resetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Cliente {
  id          String   @id @default(cuid())
  nome        String
  cpfCnpj     String?
  telefone    String?
  whatsapp    String?
  cidade      String?
  endereco    String?
  email       String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ordensServico OrdemServico[]
  notas         Nota[]

  @@index([nome])
}

model Mecanico {
  id        String   @id @default(cuid())
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  ordensServico OrdemServico[]
}

enum StatusOS {
  aberta
  em_andamento
  aguardando_peca
  aguardando_cliente
  concluida
  entregue
  cancelada
}

model OrdemServico {
  id                  Int       @id @default(autoincrement())
  data                DateTime  @default(now())
  clienteId           String
  cliente             Cliente   @relation(fields: [clienteId], references: [id])
  telefone            String?
  status              StatusOS  @default(aberta)
  mecanicoResponsavel String?
  mecanicoId          String?
  mecanico            Mecanico? @relation(fields: [mecanicoId], references: [id], onDelete: SetNull)
  previsaoEntrega     DateTime?
  formaPagamento      String?
  observacoes         String?
  pago                Boolean   @default(false)
  dataPagamento       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  itens ItemServico[]
  notas Nota[]

  @@index([clienteId])
  @@index([status])
  @@index([pago])
  @@index([mecanicoId])
}

model ItemServico {
  id             String       @id @default(cuid())
  ordemServicoId Int
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  descricao      String
  valor          Float

  @@index([ordemServicoId])
}

enum TipoNota {
  emitida
  recebida
}

model Nota {
  id             String        @id @default(cuid())
  numero         String
  dataEmissao    DateTime
  tipo           TipoNota
  valor          Float?
  observacoes    String?
  arquivoPdfPath String?
  clienteId      String?
  cliente        Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ordemServicoId Int?
  ordemServico   OrdemServico? @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([tipo])
  @@index([clienteId])
  @@index([ordemServicoId])
}

model Despesa {
  id             String   @id @default(cuid())
  descricao      String
  valor          Float
  data           DateTime
  categoria      String?
  fornecedor     String?
  formaPagamento String?
  anexoPath      String?
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  itens DespesaItem[]

  @@index([data])
  @@index([categoria])
}

model DespesaItem {
  id        String  @id @default(cuid())
  despesaId String
  despesa   Despesa @relation(fields: [despesaId], references: [id], onDelete: Cascade)
  descricao String
  valor     Float

  @@index([despesaId])
}
