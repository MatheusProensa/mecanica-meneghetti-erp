// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  dono
  funcionario
  visualizador
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  passwordHash             String
  pixKey                   String?
  dadosBancarios           String?
  failedLoginAttempts      Int       @default(0)
  lockedUntil              DateTime?
  role                     UserRole  @default(funcionario)
  podeVerDashboard         Boolean   @default(true)
  podeVerClientes          Boolean   @default(true)
  podeEditarClientes       Boolean   @default(true)
  podeExcluirClientes      Boolean   @default(true)
  podeVerOS                Boolean   @default(true)
  podeEditarOS             Boolean   @default(true)
  podeExcluirOS            Boolean   @default(true)
  podeVerFinanceiro        Boolean   @default(true)
  podeEditarFinanceiro     Boolean   @default(true)
  podeExcluirFinanceiro    Boolean   @default(true)
  podeVerDevedores         Boolean   @default(true)
  podeEditarDevedores      Boolean   @default(true)
  podeExcluirDevedores     Boolean   @default(true)
  podeVerExtras            Boolean   @default(true)
  podeEditarExtras         Boolean   @default(true)
  podeExcluirExtras        Boolean   @default(true)
  podeVerNotas             Boolean   @default(true)
  podeEditarNotas          Boolean   @default(true)
  podeExcluirNotas         Boolean   @default(true)
  podeAcessarConfiguracoes Boolean   @default(false)
  createdAt                DateTime  @default(now())

  resetTokens       PasswordResetToken[]
  pushSubscriptions PushSubscription[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Inscrição de notificação push de um navegador/dispositivo específico. Um
/// usuário pode ter várias (ex: celular e computador autorizados ao mesmo tempo).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Empresa {
  id        String   @id @default("default")
  nome      String
  endereco  String
  cidade    String
  telefone  String
  cnpj      String
  updatedAt DateTime @updatedAt
}

model Cliente {
  id          String   @id @default(cuid())
  nome        String
  cpfCnpj     String?
  telefone    String?
  whatsapp    String?
  cidade      String?
  endereco    String?
  email       String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ordensServico OrdemServico[]
  notas         Nota[]
  dividas       Divida[]
  extras        ExtraFuncionario[]

  @@index([nome])
}

model Mecanico {
  id        String   @id @default(cuid())
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  ordensServico OrdemServico[]
  extras        ExtraFuncionario[]
}

enum StatusOS {
  aberta
  em_andamento
  aguardando_peca
  aguardando_cliente
  concluida
  entregue
  cancelada
}

model OrdemServico {
  id                  Int       @id @default(autoincrement())
  data                DateTime  @default(now())
  clienteId           String
  cliente             Cliente   @relation(fields: [clienteId], references: [id])
  telefone            String?
  status              StatusOS  @default(aberta)
  mecanicoResponsavel String?
  mecanicoId          String?
  mecanico            Mecanico? @relation(fields: [mecanicoId], references: [id], onDelete: SetNull)
  previsaoEntrega     DateTime?
  formaPagamento      String?
  observacoes         String?
  pago                Boolean   @default(false)
  dataPagamento       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  itens  ItemServico[]
  notas  Nota[]
  anexos AnexoOS[]
  extras ExtraFuncionario[]

  @@index([clienteId])
  @@index([status])
  @@index([pago])
  @@index([mecanicoId])
}

model AnexoOS {
  id             String       @id @default(cuid())
  ordemServicoId Int
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  path           String
  createdAt      DateTime     @default(now())

  @@index([ordemServicoId])
}

model ItemServico {
  id             String       @id @default(cuid())
  ordemServicoId Int
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  data           DateTime
  descricao      String
  valor          Float

  @@index([ordemServicoId])
}

enum TipoNota {
  emitida
  recebida
}

model Nota {
  id             String        @id @default(cuid())
  numero         String
  dataEmissao    DateTime
  tipo           TipoNota
  valor          Float?
  observacoes    String?
  arquivoPdfPath String?
  clienteId      String?
  cliente        Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ordemServicoId Int?
  ordemServico   OrdemServico? @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([tipo])
  @@index([clienteId])
  @@index([ordemServicoId])
}

model Despesa {
  id             String   @id @default(cuid())
  descricao      String
  valor          Float
  data           DateTime
  categoria      String?
  fornecedor     String?
  formaPagamento String?
  anexoPath      String?
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  itens DespesaItem[]

  @@index([data])
  @@index([categoria])
}

model DespesaItem {
  id        String  @id @default(cuid())
  despesaId String
  despesa   Despesa @relation(fields: [despesaId], references: [id], onDelete: Cascade)
  descricao String
  valor     Float

  @@index([despesaId])
}

/// Dívidas antigas de clientes (serviços prestados antes do sistema acompanhar
/// pagamento parcelado). Os pagamentos aqui registrados são recuperação de
/// dívida — não entram no faturamento/lucro do mês em Financeiro.
model Divida {
  id          String   @id @default(cuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens      ItemDivida[]
  pagamentos PagamentoDivida[]
  anexos     AnexoDivida[]

  @@index([clienteId])
}

/// Serviços individuais que compõem a dívida (data, descrição e valor de cada
/// um), pra dar pra enviar um extrato detalhado pro cliente em vez de só um
/// valor total genérico.
model ItemDivida {
  id        String   @id @default(cuid())
  dividaId  String
  divida    Divida   @relation(fields: [dividaId], references: [id], onDelete: Cascade)
  data      DateTime
  descricao String
  valor     Float

  @@index([dividaId])
}

model AnexoDivida {
  id        String   @id @default(cuid())
  dividaId  String
  divida    Divida   @relation(fields: [dividaId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())

  @@index([dividaId])
}

model PagamentoDivida {
  id             String   @id @default(cuid())
  dividaId       String
  divida         Divida   @relation(fields: [dividaId], references: [id], onDelete: Cascade)
  data           DateTime
  valor          Float
  formaPagamento String?
  observacao     String?
  createdAt      DateTime @default(now())

  @@index([dividaId])
}

/// Pagamentos extras a funcionários vinculados a serviços específicos (fora do
/// salário/pró-labore fixo). O lucro da empresa em cada lançamento é sempre
/// derivado (valorServico − valorExtra − outrosCustos), nunca guardado direto.
model ExtraFuncionario {
  id             String        @id @default(cuid())
  data           DateTime
  mecanicoId     String
  mecanico       Mecanico      @relation(fields: [mecanicoId], references: [id])
  clienteId      String?
  cliente        Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ordemServicoId Int?
  ordemServico   OrdemServico? @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  descricao      String
  valorServico   Float
  valorExtra     Float
  outrosCustos   Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  pagamentos PagamentoExtra[]

  @@index([mecanicoId])
  @@index([clienteId])
  @@index([ordemServicoId])
  @@index([data])
}

model PagamentoExtra {
  id             String           @id @default(cuid())
  extraId        String
  extra          ExtraFuncionario @relation(fields: [extraId], references: [id], onDelete: Cascade)
  data           DateTime
  valor          Float
  formaPagamento String?
  createdAt      DateTime         @default(now())

  @@index([extraId])
}
